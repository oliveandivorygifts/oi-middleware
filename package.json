{
  "name": "@oliveandivorygifts/middleware",
  "version": "1.0.0",
  "description": "Edge-safe middleware pipeline for Cloudflare Workers, Pages, Hono, and Next.js",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "package.json"],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:prepush": "npm run lint && npm run typecheck && npm run test",
    "prepare": "npm run build",
    "setup:hooks": "node /Users/yuri_baker/dev/pre-prod/scripts/setup-cross-repo-hooks.mjs"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.19.13",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oliveandivorygifts/oi-middleware.git"
  }
}
